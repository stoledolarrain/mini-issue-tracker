<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mis Proyectos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand mb-0 h1">Gestor de Tickets</span>
            <a href="/logout" class="btn btn-outline-light btn-sm">Cerrar Sesión</a>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Mis Proyectos</h2>
    <a href="/proyectos/crear" class="btn btn-success">Nuevo Proyecto</a>
</div>

        <div class="row">
            <% if (proyectos && proyectos.length > 0) { %>
                <% proyectos.forEach(proyecto => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <h5 class="card-title"><%= proyecto.nombre %></h5>
                                <p class="card-text text-muted"><%= proyecto.descripcion %></p>
                            </div>
                            <div class="card-footer bg-transparent border-top-0">
                                <a href="/proyectos/<%= proyecto.id %>/tablero" class="btn btn-primary w-100">Ver Tablero</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center mt-5">
                    <p class="text-muted">No tienes proyectos asignados aún.</p>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>