<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Ticket</title>
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow border-0">
                    <div class="card-body p-4">
                        <h3 class="mb-4">Editar Ticket</h3>
                        
                        <!-- Formulario de Actualización -->
                        <form action="/proyectos/<%= proyecto.id %>/tickets/<%= ticket.id %>/editar" method="POST">
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Título del Ticket</label>
                                <input type="text" name="titulo" class="form-control" value="<%= ticket.titulo %>" required>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Descripción</label>
                                <textarea name="descripcion" class="form-control" rows="3"><%= ticket.descripcion %></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Estado en el Tablero</label>
                                <select name="estado" class="form-select border-primary bg-primary bg-opacity-10">
                                    <option value="Pendiente" <%= ticket.estado === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
                                    <option value="En Progreso" <%= ticket.estado === 'En Progreso' ? 'selected' : '' %>>En Progreso</option>
                                    <option value="Completado" <%= ticket.estado === 'Completado' ? 'selected' : '' %>>Completado</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Asignar a:</label>
                                <select name="usuarioAsignadoId" class="form-select">
                                    <option value="">Sin asignar</option>
                                    <% usuarios.forEach(user => { %>
                                        <option value="<%= user.id %>" <%= ticket.usuarioAsignadoId === user.id ? 'selected' : '' %>>
                                            <%= user.nombre %> (<%= user.email %>)
                                        </option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end mb-3">
                                <a href="/proyectos/<%= proyecto.id %>/tablero" class="btn btn-outline-secondary me-md-2">Cancelar</a>
                                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                            </div>
                        </form>

                        <!-- Botón de Eliminar (Sin cuadros decorativos) -->
                        <div class="text-end border-top pt-3">
                            <form action="/proyectos/<%= proyecto.id %>/tickets/<%= ticket.id %>/eliminar" method="POST" onsubmit="return confirm('¿Estás seguro de que deseas eliminar este ticket?');">
                                <button type="submit" class="btn btn-danger">Eliminar Ticket</button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>