<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Nuevo Proyecto</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light">
    <div class="container mt-5">
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="card shadow border-0">
            <div class="card-body p-4">
              <h3 class="mb-4">Crear Nuevo Proyecto</h3>
              
              <% if (typeof error !== 'undefined' && error) { %>
                  <div class="alert alert-danger" role="alert">
                      <%= error %>
                  </div>
              <% } %>

              <form action="/proyectos/crear" method="POST">
                <div class="mb-3">
                  <label class="form-label fw-bold">Nombre del Proyecto</label>
                  <input
                    type="text"
                    name="nombre"
                    class="form-control"
                    placeholder="Ej: Sistema de Inventario"
                    value="<%= typeof datos !== 'undefined' && datos.nombre ? datos.nombre : '' %>"
                    required
                  />
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Descripción</label>
                  <textarea
                    name="descripcion"
                    class="form-control"
                    rows="3"
                    placeholder="¿De qué trata este proyecto?"
                  ><%= typeof datos !== 'undefined' && datos.descripcion ? datos.descripcion : '' %></textarea>
                </div>
                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                  <a href="/proyectos" class="btn btn-outline-secondary me-md-2"
                    >Cancelar</a
                  >
                  <button type="submit" class="btn btn-primary">
                    Guardar Proyecto
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>