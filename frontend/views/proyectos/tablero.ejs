<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tablero - <%= proyecto.nombre %></title>
    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .kanban-column {
            min-height: 70vh;
            border-radius: 8px;
        }
        .ticket-card {
            transition: transform 0.2s;
            cursor: pointer;
        }
        .ticket-card:hover {
            transform: translateY(-3px);
        }
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark shadow-sm mb-4">
        <div class="container-fluid px-4">
            <a href="/proyectos" class="navbar-brand d-flex align-items-center">
                <span class="me-2"> <-- </span> Volver a Proyectos
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="navbar-text text-white fw-bold">
                    <%= proyecto.nombre %>
                </span>
                <a href="/proyectos/<%= proyecto.id %>/tickets/crear" class="btn btn-success btn-sm">Nuevo Ticket</a>
            </div>
            <div>
                <a href="/logout" class="btn btn-outline-danger btn-sm">Cerrar Sesión</a>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-4">
        <div class="row g-4">
            
            <div class="col-md-4">
                <div class="card bg-secondary bg-opacity-10 border-0 kanban-column">
                    <div class="card-header bg-secondary text-white fw-bold d-flex justify-content-between">
                        Pendiente <span><%= pendientes.length %></span>
                    </div>
                    <div class="card-body p-2">
                        <% if (pendientes.length > 0) { %>
                            <% pendientes.forEach(ticket => { %>
                                <div class="card mb-3 shadow-sm border-0 ticket-card">
                                    <div class="card-body">
                                        <h6 class="card-title fw-bold mb-1">
                                            <a href="/proyectos/<%= proyecto.id %>/tickets/<%= ticket.id %>/editar" class="text-decoration-none text-dark">
                                                (Click para editar) <%= ticket.titulo %>
                                            </a>
                                        </h6>
                                        <p class="small text-muted mb-2"><%= ticket.descripcion %></p>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="badge bg-light text-dark border">
                                                <%= ticket.usuarioAsignadoId ? 'Asignado' : 'Sin asignar' %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-muted mt-3 small">No hay tickets pendientes</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-primary bg-opacity-10 border-0 kanban-column">
                    <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between">
                        En Progreso <span><%= enProgreso.length %></span>
                    </div>
                    <div class="card-body p-2">
                        <% if (enProgreso.length > 0) { %>
                            <% enProgreso.forEach(ticket => { %>
                                <div class="card mb-3 shadow-sm border-0 ticket-card">
                                    <div class="card-body">
                                        <h6 class="card-title fw-bold mb-1">
                                            <a href="/proyectos/<%= proyecto.id %>/tickets/<%= ticket.id %>/editar" class="text-decoration-none text-primary">
                                                (Click para editar) <%= ticket.titulo %>
                                            </a>
                                        </h6>
                                        <p class="small text-muted mb-2"><%= ticket.descripcion %></p>
                                        <span class="badge bg-primary text-white">En Progreso</span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-muted mt-3 small">No hay tickets en curso</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-success bg-opacity-10 border-0 kanban-column">
                    <div class="card-header bg-success text-white fw-bold d-flex justify-content-between">
                        Completado <span><%= completados.length %></span>
                    </div>
                    <div class="card-body p-2">
                        <% if (completados.length > 0) { %>
                            <% completados.forEach(ticket => { %>
                                <div class="card mb-3 shadow-sm border-0 ticket-card opacity-75">
                                    <div class="card-body">
                                        <h6 class="card-title fw-bold mb-1">
                                            <!-- Se eliminó la clase text-decoration-line-through aquí -->
                                            <a href="/proyectos/<%= proyecto.id %>/tickets/<%= ticket.id %>/editar" class="text-decoration-none text-success">
                                                (Click para editar) <%= ticket.titulo %>
                                            </a>
                                        </h6>
                                        <p class="small text-muted mb-2"><%= ticket.descripcion %></p>
                                        <span class="badge bg-success text-white">Terminado</span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center text-muted mt-3 small">No hay tickets completados</p>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>